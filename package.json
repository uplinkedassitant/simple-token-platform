{
  "name": "simple-token-platform",
  "version": "1.0.0",
  "description": "Create SPL token, mint 1B supply, add 98% to Meteora DLMM pool, trade via web platform",
  "main": "index.js",
  "scripts": {
    "create-token": "ts-node src/create-token.ts",
    "setup-pool": "ts-node src/setup-pool.ts",
    "dev:platform": "cd trading-platform && npm run dev",
    "build:platform": "cd trading-platform && npm run build",
    "install:platform": "cd trading-platform && npm install"
  },
  "keywords": [
    "solana",
    "spl-token",
    "meteora",
    "dlmm",
    "defi"
  ],
  "author": "Jay @ Uplinked LLC",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@meteora-ag/dlmm": "^1.4.5",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
