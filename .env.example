# Token Configuration
# Copy this file to .env.local and fill in your values

# Your token's mint address
NEXT_PUBLIC_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS

# Token display name
NEXT_PUBLIC_TOKEN_NAME=Your Token Name

# Token symbol/ticker
NEXT_PUBLIC_TOKEN_SYMBOL=TOKEN

# Token decimals (usually 9 for SPL tokens)
NEXT_PUBLIC_TOKEN_DECIMALS=9

# Pool Configuration
# Your Meteora DLMM pool address
NEXT_PUBLIC_POOL_ADDRESS=YOUR_POOL_ADDRESS

# Network Configuration
# devnet, testnet, or mainnet-beta
NEXT_PUBLIC_NETWORK=devnet

# RPC URL (optional, uses default if not specified)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
